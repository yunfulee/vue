{
  "name": "vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,vue}\" --fix",
    "format": "prettier --write \"**/*.{js,vue,json,css,scss,md}\"",
    "test": "vitest",
    "prepare": "husky install"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "pinia": "^3.0.4",
    "vant": "^4.9.17",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.26.8",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "sass": "^1.85.1",
    "terser": "^5.39.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.1.0",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
